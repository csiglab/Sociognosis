{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/product-space-node.schema.json",
  "title": "Sociognosis Index Node Schema",
  "description": "A formal ontic-epistemic schema underlying the structure of understanding and agency in social reality.",
  "type": "object",
  "required": [
    "id",
    "name",
    "category",
    "inheritanceLevel",
    "description",
    "functionalRoles",
    "domainScope",
    "historicalContext",
    "specific",
    "relationships",
    "metadata",
    "references"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "description": "Category of the entity in the ontic epistemic schema for Sociognosis.",
      "enum": [
        "Epistemic Purpose",
        "Reality",
        "Observation Interface",
        "Observation Encoding",
        "Epistemic Representation Form (Epistemic Blueprint)",
        "Concrete Epistemic Artifact",
        "Epistemic Gap",
        "Epistemic Agent",
        "Epistemic Goal",
        "Epistemic Process (Activity)",
        "Epistemic Standard",
        "Encoding Substrate",
        "Epistemic Domain (Target Domain)",
        "Epistemic Constraint",
        "Epistemic Infrastructure",
        "Epistemic Feedback",
        "Epistemic Act",
        "Epistemic Principle",
        "Epistemic Prior (Inductive Bias)",
        "Epistemic Strategy",
        "Epistemic Framework",
        "Epistemic Operator"
      ]
    },
    "inheritanceLevel": {
      "type": "integer",
      "minimum": 0
    },
    "description": {
      "type": "string"
    },
    "longDescription": {
      "type": "string"
    },
    "functionalRoles": {
      "type": "array",
      "description": "The set of roles that the node (entity) plays in our epistemic efforts to capture a section of reality, analogous to the Scaffold Status.",
      "items": {
        "type": "string"
      }
    },
    "domainScope": {
      "type": "array",
      "description": "Economic, industrial, or production domains where the node operates",
      "items": {
        "type": "string"
      }
    },
    "historicalContext": {
      "type": "object",
      "required": [
        "summary",
        "chronology"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "chronology": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "year",
              "event",
              "context"
            ],
            "properties": {
              "year": {
                "type": "number"
              },
              "event": {
                "type": "string"
              },
              "context": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "specific": {
      "type": "object",
      "description": "Category-specific structured extension fields"
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "relationshipType",
          "targetNodeId",
          "description"
        ],
        "properties": {
          "relationshipFamily": {
            "type": "string",
            "enum": [
              "FUNCTIONAL",
              "STRUCTURAL",
              "CAPABILITY_DEPENDENCY",
              "VALUE_CHAIN",
              "MARKET_RELATION",
              "GOVERNANCE",
              "TEMPORAL_EVOLUTION",
              "COMPOSITIONAL",
              "CLASSIFICATION"
            ]
          },
          "relationshipType": {
            "type": "string",
            "enum": [
              "PRODUCES",
              "CONSUMES",
              "ENABLES",
              "REQUIRES",
              "DEPENDS_ON",
              "PART_OF",
              "TRANSFORMS_INTO",
              "SPECIALIZES",
              "GENERALIZES",
              "COMPLIES_WITH",
              "CONSTRAINED_BY",
              "COMPETES_WITH",
              "SUBSTITUTES_FOR",
              "COMPLEMENTS",
              "ORCHESTRATED_BY",
              "EVOLVES_FROM",
              "SUPERSEDES"
            ]
          },
          "targetNodeId": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": [
        "tags",
        "confidenceScore",
        "sourceReference",
        "createdAt",
        "auditTrail"
      ],
      "properties": {
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidenceScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "sourceReference": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "auditTrail": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "reviewDate",
              "reviewNote"
            ],
            "properties": {
              "reviewDate": {
                "type": "string",
                "format": "date"
              },
              "reviewNote": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "description"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "link": {
            "type": "string",
            "format": "uri"
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "category": {
            "const": "Epistemic Purpose"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/EpistemicPurposeSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Reality"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/RealitySpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Observation Interface"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/ObservationInterfaceSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Observation Encoding"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/ObservationEncodingSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Epistemic Representation Form (Epistemic Blueprint)"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/EpistemicRepresentationFormSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Concrete Epistemic Artifact"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/ConcreteEpistemicArtifactSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Epistemic Gap"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/EpistemicGapSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Epistemic Agent"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/EpistemicAgentSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Epistemic Goal"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/EpistemicGoalSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Epistemic Process (Activity)"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/EpistemicProcessSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Epistemic Standard"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/EpistemicStandardSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Encoding Substrate"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/EncodingSubstrateSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Epistemic Domain (Target Domain)"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/EpistemicDomainSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Epistemic Constraint"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/EpistemicConstraintSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Epistemic Infrastructure"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/EpistemicInfrastructureSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Epistemic Feedback"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/EpistemicFeedbackSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Epistemic Act"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/EpistemicActSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Epistemic Principle"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/EpistemicPrincipleSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Epistemic Prior (Inductive Bias)"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/EpistemicPriorSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Epistemic Strategy"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/EpistemicStrategySpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Epistemic Framework"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/EpistemicFrameworkSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Epistemic Operator"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/EpistemicOperatorSpecific"
          }
        }
      }
    }
  ],
  "$defs": {
    "EpistemicPurposeSpecific": {
      "type": "object",
      "required": ["purposeType"],
      "properties": {
        "purposeType": {
          "type": "string",
          "description": "The telos or intended epistemic objective.",
          "enum": [
            "explanation",
            "prediction",
            "control",
            "diagnosis",
            "discovery",
            "description",
            "forecasting",
            "intervention",
            "understanding",
            "other"
          ]
        },
        "intendedOutcome": {
          "type": "string",
          "description": "Free-text description of what the knowledge is supposed to achieve."
        }
      }
    },
    "RealitySpecific": {
      "type": "object",
      "required": ["onticLayer", "onticCategory"],
      "properties": {
        "onticLayer": {
          "type": "string",
          "description": "The primary layer of reality according to the ontic schema.",
          "enum": ["Ontic", "Synontic", "MetaOntic"]
        },
        "onticCategory": {
          "type": "string",
          "description": "The specific ontic kind, drawing from the ontology template.",
          "enum": [
            "Substantive",
            "Processual",
            "Entity",
            "Mechanism",
            "Event",
            "Process",
            "Stochastic",
            "EventStream",
            "MixtureEventStream",
            "Phenomena",
            "Epiphenomena",
            "Agent",
            "Goal",
            "SelfOrganizing",
            "Institutional",
            "Rhizome",
            "CausalRelation",
            "SignificantRelation",
            "CoordinationProtocol",
            "Affordance",
            "Space",
            "Time",
            "Environment",
            "Substrate",
            "Property",
            "Aspect",
            "VariableAspect",
            "State",
            "Information"
          ]
        },
        "realityDescription": {
          "type": "string",
          "description": "Summary of the specific segment of reality being referenced."
        },
        "latentStructures": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Hidden or unobserved mechanisms thought to underlie the phenomena."
        }
      }
    },
    "ObservationInterfaceSpecific": {
      "type": "object",
      "required": ["transductionMethod", "encodingFormat"],
      "properties": {
        "transductionMethod": {
          "type": "string",
          "description": "How raw phenomena are converted into a signal (e.g., CMOS sensor, thermocouple, human retina)."
        },
        "samplingStrategy": {
          "type": "string",
          "description": "How continuous reality is sampled (e.g., periodic, event-triggered)."
        },
        "quantization": {
          "type": "string",
          "description": "Quantization scheme (e.g., 8-bit ADC, categorical bins)."
        },
        "encodingFormat": {
          "type": "string",
          "description": "Format of the initial encoded observation (e.g., JPEG, CSV, neural spike train)."
        },
        "storageMedium": {
          "type": "string",
          "description": "Where the encoded observation is first stored (e.g., SD card, working memory)."
        }
      }
    },
    "ObservationEncodingSpecific": {
      "type": "object",
      "required": ["encodingStandard"],
      "properties": {
        "encodingStandard": {
          "type": "string",
          "description": "Formal or conventional standard for the encoded data (e.g., MIME type, file format, neural code)."
        },
        "resolution": {
          "type": "string",
          "description": "Spatial/temporal/intensity resolution of the encoding."
        },
        "compression": {
          "type": "string",
          "description": "Whether lossy or lossless compression is used."
        }
      }
    },
    "EpistemicRepresentationFormSpecific": {
      "type": "object",
      "required": ["formType"],
      "properties": {
        "formType": {
          "type": "string",
          "description": "The abstract representational genus (e.g., DAG, structural equation, graph, polynomial).",
          "enum": [
            "DirectedAcyclicGraph",
            "StructuralEquation",
            "PolynomialEquation",
            "DifferentialEquation",
            "BayesianNetwork",
            "Matrix",
            "Hypergraph",
            "LogicalFormula",
            "DecisionTree",
            "NeuralNetworkArchitecture",
            "other"
          ]
        },
        "formalSystem": {
          "type": "string",
          "description": "The mathematical or logical system that governs the form (e.g., algebra, predicate logic, probability theory)."
        },
        "expressiveness": {
          "type": "string",
          "description": "What class of relations or functions the form can capture (e.g., linear, non-linear, cyclic)."
        }
      }
    },
    "ConcreteEpistemicArtifactSpecific": {
      "type": "object",
      "required": ["artifactType", "encodingFormat"],
      "properties": {
        "artifactType": {
          "type": "string",
          "description": "Concrete kind of artifact (e.g., fitted model, dataset, specific equation, simulation run).",
          "enum": ["equation", "dataset", "model", "graph", "table", "text", "code", "image", "other"]
        },
        "encodingFormat": {
          "type": "string",
          "description": "Syntax or serialization (e.g., CSV, JSON, Python code, LaTeX)."
        },
        "verificationStatus": {
          "type": "string",
          "enum": ["unverified", "verified", "falsified", "underReview"]
        },
        "artifactHash": {
          "type": "string",
          "description": "Content hash for identity and integrity."
        }
      }
    },
    "EpistemicGapSpecific": {
      "type": "object",
      "required": ["gapDescription"],
      "properties": {
        "gapDescription": {
          "type": "string",
          "description": "What is unknown or inadequately modeled."
        },
        "scope": {
          "type": "string",
          "description": "Boundaries of the gap (e.g., spatial, temporal, conceptual)."
        },
        "urgency": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "researchQuestions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "EpistemicAgentSpecific": {
      "type": "object",
      "required": ["agentType"],
      "properties": {
        "agentType": {
          "type": "string",
          "enum": ["individualHuman", "researchTeam", "institution", "automatedSystem", "AI", "other"]
        },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Specific cognitive or computational capabilities."
        },
        "domainExpertise": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "EpistemicGoalSpecific": {
      "type": "object",
      "required": ["goalType"],
      "properties": {
        "goalType": {
          "type": "string",
          "description": "The epistemic outcome the goal aims for.",
          "enum": [
            "identifyCausalMechanisms",
            "estimateParameters",
            "discoverLatentVariables",
            "classifyEntities",
            "predictFutureStates",
            "explainObservedPhenomena",
            "reduceUncertainty",
            "detectAnomalies",
            "estimateRisk",
            "constructTaxonomies",
            "inferHiddenStates",
            "evaluateInterventions",
            "improveForecastAccuracy",
            "characterizeSystemStructure",
            "determineBoundaryConditions",
            "identifyGoverningLaws",
            "measureQuantities",
            "validateHypotheses",
            "generateHypotheses",
            "optimizeModelPerformance",
            "other"
          ]
        },
        "priority": {
          "type": "string",
          "enum": ["primary", "secondary", "background"]
        },
        "targetRealitySection": {
          "type": "string",
          "description": "Reference to the reality segment the goal addresses."
        }
      }
    },
    "EpistemicProcessSpecific": {
      "type": "object",
      "required": ["processType"],
      "properties": {
        "processType": {
          "type": "string",
          "enum": [
            "scientificMethod",
            "bayesianUpdating",
            "trainingPipeline",
            "experimentalCycle",
            "simulationStudy",
            "literatureReview",
            "modelComparison",
            "dataCollection",
            "other"
          ]
        },
        "steps": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Sequence of activities or phases."
        },
        "toolDependencies": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "EpistemicStandardSpecific": {
      "type": "object",
      "required": ["standardType"],
      "properties": {
        "standardType": {
          "type": "string",
          "enum": [
            "logicalConsistency",
            "statisticalSignificance",
            "reproducibility",
            "robustness",
            "falsifiability",
            "predictiveAccuracy",
            "explanatoryPower",
            "parsimony",
            "other"
          ]
        },
        "threshold": {
          "type": "string",
          "description": "Quantitative or qualitative threshold (e.g., p<0.05)."
        },
        "appliedTo": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Types of artifacts or processes this standard evaluates."
        }
      }
    },
    "EncodingSubstrateSpecific": {
      "type": "object",
      "required": ["substrateType"],
      "properties": {
        "substrateType": {
          "type": "string",
          "enum": ["paper", "ink", "electromagneticSignal", "siliconMemory", "biologicalTissue", "other"]
        },
        "physicalProperties": {
          "type": "string",
          "description": "Key physical characteristics (e.g., magnetic coercivity, optical contrast)."
        }
      }
    },
    "EpistemicDomainSpecific": {
      "type": "object",
      "required": ["domainType"],
      "properties": {
        "domainType": {
          "type": "string",
          "description": "The broad area of reality targeted.",
          "enum": [
            "physicalSystem",
            "biologicalSystem",
            "socialSystem",
            "computationalSystem",
            "economicSystem",
            "ecologicalSystem",
            "cognitiveSystem",
            "other"
          ]
        },
        "scopeDescription": {
          "type": "string"
        }
      }
    },
    "EpistemicConstraintSpecific": {
      "type": "object",
      "required": ["constraintType"],
      "properties": {
        "constraintType": {
          "type": "string",
          "enum": [
            "noise",
            "limitedData",
            "computationalComplexity",
            "identifiabilityIssue",
            "measurementError",
            "ignorance",
            "intractability",
            "stochasticity",
            "higherOrderStochasticity",
            "chaos",
            "nonlinearity",
            "uncertaintyPropagation",
            "observationalLimitation",
            "other"
          ]
        },
        "impactDescription": {
          "type": "string"
        },
        "mitigationStrategies": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "EpistemicInfrastructureSpecific": {
      "type": "object",
      "required": ["infrastructureType"],
      "properties": {
        "infrastructureType": {
          "type": "string",
          "enum": [
            "sensor",
            "laboratory",
            "softwareSystem",
            "database",
            "computationalCluster",
            "publicationVenue",
            "repository",
            "other"
          ]
        },
        "components": {
          "type": "array",
          "items": { "type": "string" }
        },
        "accessibility": {
          "type": "string",
          "enum": ["open", "restricted", "proprietary"]
        }
      }
    },
    "EpistemicFeedbackSpecific": {
      "type": "object",
      "required": ["feedbackType"],
      "properties": {
        "feedbackType": {
          "type": "string",
          "enum": [
            "predictionError",
            "unexpectedObservation",
            "failedIntervention",
            "successfulReplication",
            "sensorSaturation",
            "modelDivergence",
            "comparisonSnapshot",
            "other"
          ]
        },
        "source": {
          "type": "string",
          "description": "Which artifact or reality segment generated the feedback."
        },
        "magnitude": {
          "type": "string",
          "description": "Strength or significance of the feedback signal."
        }
      }
    },
    "EpistemicActSpecific": {
      "type": "object",
      "required": ["actType"],
      "properties": {
        "actType": {
          "type": "string",
