{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/product-space-node.schema.json",
  "title": "Production Space Node Schema",
  "description": "Schema for representing the production space, production processes, and enabling capabilities including techniques, infrastructure, constraints, and market structures. Mirrors the storage model defined in docs/data/prd/schema/notes.",
  "type": "object",
  "required": [
    "id",
    "name",
    "tags",
    "layer",
    "category",
    "description",
    "chronology",
    "relationships",
    "specific",
    "metadata",
    "references"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Globally unique identifier for the element."
    },
    "name": {
      "type": "string",
      "description": "Canonical name of the element."
    },
    "tags": {
      "type": "array",
      "description": "Tag Set — collection of keywords, classifications, or labels used for indexing, filtering, and discovery.",
      "items": {
        "type": "string"
      }
    },
    "layer": {
      "type": "string",
      "description": "The ontological layer to which the element belongs.",
      "enum": [
        "Reality",
        "Problem",
        "Technical",
        "Production",
        "Product",
        "Economic"
      ]
    },
    "category": {
      "type": "string",
      "description": "The direct conceptual category of the element.",
      "enum": [
        "Reality",
        "Technical Domain",
        "Technical System",
        "Action Interface & Actuation",
        "Concrete Technical Artifact",
        "Technical Blueprint",
        "Technical Agent",
        "Technical Activity",
        "Technical Standard",
        "Technical Constraint",
        "Technical Infrastructure",
        "Technical Feedback",
        "Technical Strategy",
        "Technical Framework",
        "Technical Mechanism",
        "Production Technical Object",
        "Constitutive Technical Object",
        "Technique",
        "Technical Problem",
        "Technical Requirement",
        "Operative Technique",
        "Constitutive Technique",
        "Technical Purpose",
        "Technical Architecture",
        "Technical Specification",
        "Technical Evolution",
        "Technical Labor",
        "Technical Institution",
        "Technical Research",
        "Technical Competence",
        "Technical Failure",
        "Verification",
        "Maintenance",
        "Security",
        "Resource",
        "Technical Obsolescence",
        "Production System",
        "Production Process",
        "Production Activity",
        "Production Operation",
        "Production Facility",
        "Production Line",
        "Task",
        "Product",
        "Product Group",
        "Industry",
        "Industrial Group",
        "Sector",
        "Major Sector",
        "Production Capability",
        "Production Capacity"
      ]
    },
    "description": {
      "type": "string",
      "description": "Short description — concise summary of the element."
    },
    "longDescription": {
      "type": "string",
      "description": "Long description — comprehensive explanation of the element, including its purpose, meaning, and significance."
    },
    "chronology": {
      "type": "object",
      "description": "Chronology — historical development of the element, including origin, major revisions, predecessors, successors, and significant milestones.",
      "properties": {
        "summary": {
          "type": "string"
        },
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "year",
              "event"
            ],
            "properties": {
              "year": {
                "type": "number"
              },
              "event": {
                "type": "string"
              },
              "context": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "relationships": {
      "type": "array",
      "description": "Relationship Set — structured collection of semantic relationships linking the element to other ontology elements.",
      "items": {
        "type": "object",
        "required": [
          "targetNodeId",
          "relationshipType"
        ],
        "properties": {
          "targetNodeId": {
            "type": "string",
            "description": "ID of the related node."
          },
          "relationshipFamily": {
            "type": "string",
            "description": "The family/category of the relationship (e.g., Functional, Structural, Capability Dependency, Value Chain, Market Relation, Governance, Temporal Evolution, Compositional, Classification)."
          },
          "relationshipType": {
            "type": "string",
            "description": "The specific link type.",
            "enum": [
              "Is A",
              "Instance Of",
              "Part Of",
              "Has Part",
              "Depends On",
              "Uses",
              "Produces",
              "Consumes",
              "Transforms",
              "Implements",
              "Specifies",
              "Constrains",
              "Controls",
              "Measures",
              "Verifies",
              "Maintains",
              "Repairs",
              "Enables",
              "Supports",
              "Influences",
              "Communicates With",
              "Interacts With",
              "Located In",
              "Owned By",
              "Managed By",
              "Created By",
              "Derived From",
              "Precedes",
              "Succeeds",
              "Replaces",
              "Equivalent To",
              "Associated With"
            ]
          },
          "description": {
            "type": "string",
            "description": "Explanation of why this relationship is relevant."
          }
        }
      }
    },
    "specific": {
      "type": "object",
      "description": "Category-Specific Characterization — attributes specific to the element's category that are not covered by the generic schema."
    },
    "metadata": {
      "type": "object",
      "description": "Metadata — administrative and descriptive information such as author, creation date, last modification date, version, lifecycle status, provenance, confidence level, and licensing information.",
      "properties": {
        "inheritanceLevel": {
          "type": "integer",
          "minimum": 0,
          "description": "Taxonomic inheritance level of the element within its category."
        },
        "confidenceScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence level of the element's characterization."
        },
        "sourceReference": {
          "type": "string",
          "description": "Provenance or primary source of the element's data."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation date of the element record."
        },
        "auditTrail": {
          "type": "array",
          "description": "Review and modification history.",
          "items": {
            "type": "object",
            "required": [
              "reviewDate",
              "reviewNote"
            ],
            "properties": {
              "reviewDate": {
                "type": "string",
                "format": "date"
              },
              "reviewNote": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "references": {
      "type": "array",
      "description": "References — bibliographic references, standards, specifications, technical documentation, academic literature, and other supporting sources.",
      "items": {
        "type": "object",
        "required": [
          "title",
          "description"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "link": {
            "type": [
              "string",
              "null"
            ],
            "format": "uri"
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "category": {
            "const": "Product"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/ProductSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Production Process"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/ProductionProcessSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Technique"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/TechniqueSpecific"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "category": {
            "const": "Production Capability"
          }
        }
      },
      "then": {
        "properties": {
          "specific": {
            "$ref": "#/$defs/ProductionCapabilitySpecific"
          }
        }
      }
    }
  ],
  "$defs": {
    "ProductSpecific": {
      "type": "object",
      "required": [
        "materiality",
        "useCase",
        "lifeCycleStage"
      ],
      "properties": {
        "materiality": {
          "type": "string"
        },
        "useCase": {
          "type": "string"
        },
        "lifeCycleStage": {
          "type": "string",
          "enum": [
            "concept",
            "prototype",
            "production",
            "distribution",
            "consumption",
            "obsolete"
          ]
        }
      }
    },
    "ProductionProcessSpecific": {
      "type": "object",
      "required": [
        "inputs",
        "outputs",
        "transformationLogic"
      ],
      "properties": {
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "transformationLogic": {
          "type": "string"
        }
      }
    },
    "TechniqueSpecific": {
      "type": "object",
      "required": [
        "knowledgeType",
        "codificationLevel",
        "transferMechanism"
      ],
      "properties": {
        "knowledgeType": {
          "type": "string"
        },
        "codificationLevel": {
          "type": "string",
          "enum": [
            "tacit",
            "explicit",
            "hybrid"
          ]
        },
        "transferMechanism": {
          "type": "string"
        }
      }
    },
    "ProductionCapabilitySpecific": {
      "type": "object",
      "required": [
        "capabilityType",
        "proficiencyLevel",
        "measurability"
      ],
      "properties": {
        "capabilityType": {
          "type": "string"
        },
        "proficiencyLevel": {
          "type": "string"
        },
        "measurability": {
          "type": "string"
        }
      }
    }
  },
  "additionalProperties": true
}